    </div>
  );
}

// =====================================================
// MAIN APP COMPONENT
// =====================================================
export default function App() {
  const [db, setDb] = useState(() => {
    if (typeof window === 'undefined') return createDefaultState();

    const saved = localStorage.getItem('myobound_db');
    if (!saved) return createDefaultState();

    try {
      const parsed = JSON.parse(saved);
      const base = createDefaultState();
      return {
        ...base,
        ...parsed,
        plan: { ...base.plan, ...(parsed.plan || {}) },
        settings: { ...base.settings, ...(parsed.settings || {}) },
        slots: Array.isArray(parsed.slots) && parsed.slots.length ? parsed.slots : base.slots,
        history: Array.isArray(parsed.history) ? parsed.history : base.history
      };
    } catch {
      return createDefaultState();
    }
  });

  useEffect(() => {
    localStorage.setItem('myobound_db', JSON.stringify(db));
  }, [db]);

  const [screen, setScreen] = useState(db.onboarded ? 'HUB' : 'WELCOME');
  const [pendingCardio, setPendingCardio] = useState(null);

  const themeObj = db.settings.theme === 'dark' ? COLORS.dark : COLORS.light;

  const handleComplete = (data, isManual = false) => {
    const entry = {
      date: new Date().toISOString(),
      block: db.currentBlock,
      slotIndex: isManual ? -1 : db.currentSlotIndex,
      type: data.type || 'SESSION',
      data,
      official: !isManual
    };

    const nextIdx = isManual ? db.currentSlotIndex : db.currentSlotIndex + 1;

    if (!isManual && nextIdx >= 42) {
      setDb(prev => ({
        ...prev,
        history: [entry, ...prev.history],
        onboarded: false,
        officialStarted: false,
        currentSlotIndex: 0,
        currentBlock: prev.currentBlock + 1
      }));
      setScreen('WELCOME');
    } else {
      setDb(prev => ({
        ...prev,
        history: [entry, ...prev.history],
        currentSlotIndex: nextIdx
      }));
      setScreen('HUB');
    }
  };

  const render = () => {
    switch (screen) {
      case 'WELCOME':
        return <WelcomeScreen onNext={() => setScreen('SETUP')} themeObj={themeObj} />;

      case 'SETUP':
        return <SetupWizard db={db} setDb={setDb} onComplete={() => setScreen('HUB')} themeObj={themeObj} />;

      case 'HUB':
        return <HubScreen db={db} setDb={setDb} onNavigate={setScreen} themeObj={themeObj} />;

      case 'STRENGTH':
        return <StrengthWorkout db={db} onComplete={handleComplete} onCancel={() => setScreen('HUB')} themeObj={themeObj} />;

      case 'STRENGTH_UPPER':
        return <StrengthWorkout db={db} workoutTypeOverride="UPPER" onComplete={d => handleComplete(d, true)} onCancel={() => setScreen('HUB')} themeObj={themeObj} />;

      case 'STRENGTH_LOWER':
        return <StrengthWorkout db={db} workoutTypeOverride="LOWER" onComplete={d => handleComplete(d, true)} onCancel={() => setScreen('HUB')} themeObj={themeObj} />;

      case 'CARDIO':
        return (
          <CardioWorkout
            db={db}
            onComplete={d => { setPendingCardio(d); setScreen('CORE'); }}
            onCancel={() => { setPendingCardio(null); setScreen('HUB'); }}
            themeObj={themeObj}
          />
        );

      case 'MANUAL_CARDIO':
        return (
          <CardioWorkout
            db={db}
            onComplete={d => { setPendingCardio(d); setScreen('MANUAL_CORE'); }}
            onCancel={() => { setPendingCardio(null); setScreen('HUB'); }}
            themeObj={themeObj}
          />
        );

      case 'CORE':
        return (
          <CoreFinisher
            db={db}
            onComplete={d => {
              handleComplete({ type: 'CARDIO+CORE', cardio: pendingCardio, core: d });
              setPendingCardio(null);
            }}
            onCancel={() => { setPendingCardio(null); setScreen('HUB'); }}
            themeObj={themeObj}
          />
        );

      case 'MANUAL_CORE':
        return (
          <CoreFinisher
            db={db}
            onComplete={d => {
              if (pendingCardio) {
                handleComplete({ type: 'CARDIO+CORE', cardio: pendingCardio, core: d }, true);
              } else {
                handleComplete({ type: 'CORE', ...d }, true);
              }
              setPendingCardio(null);
            }}
            onCancel={() => { setPendingCardio(null); setScreen('HUB'); }}
            themeObj={themeObj}
          />
        );

      case 'HISTORY':
        return <HistoryScreen db={db} onBack={() => setScreen('HUB')} themeObj={themeObj} />;

      case 'SETTINGS':
        return <SettingsScreen db={db} setDb={setDb} onBack={() => setScreen('HUB')} themeObj={themeObj} />;

      case 'OFF':
        return (
          <div className="flex-1 flex flex-col items-center justify-center p-8 text-center" style={{ backgroundColor: themeObj.bg }}>
            <RotateCcw size={80} className="mb-6 opacity-30" />
            <h1 className="text-4xl font-black mb-4 uppercase leading-tight">Rest Day</h1>
            <p className="text-lg opacity-60 font-medium mb-10 leading-relaxed">Hydrate and recover.</p>
            <Button onClick={() => handleComplete({ type: 'REST' })} themeObj={themeObj}>Confirm Recovery</Button>
          </div>
        );

      default:
        return null;
    }
  };

  return (
    <div
      className="w-full h-screen flex flex-col overflow-hidden font-sans select-none relative transition-colors duration-300 antialiased"
      style={{ backgroundColor: themeObj.bg, color: themeObj.text }}
    >
      {render()}
      {['HUB', 'HISTORY', 'SETTINGS'].includes(screen) && (
        <BottomNav currentScreen={screen} onNavigate={setScreen} themeObj={themeObj} />
      )}
    </div>
  );
}
