const getAdviceForExercise = (pastLogs) => {
  if (!pastLogs || pastLogs.length === 0) return { text: 'CALIBRATION', color: 'textMuted' };
  const limitedLogs = pastLogs.filter(l => l.status === 'limit');
  if (limitedLogs.length > 0) {
    const earliestLimitCycle = pastLogs.findIndex(l => l.status === 'limit') + 1;
    if (earliestLimitCycle <= 3) return { text: 'DROP LOAD', color: 'text-red-500' };
    return { text: 'KEEP LOAD', color: 'text-blue-500' };
  }
  return { text: 'INCREASE LOAD', color: 'text-green-500' };
};

// =====================================================
// AUDIO ENGINE
// =====================================================
let audioCtx = null;

const getAudioCtx = () => {
  if (typeof window === 'undefined') return null;
  const Ctx = window.AudioContext || window.webkitAudioContext;
  if (!Ctx) return null;
  if (!audioCtx) audioCtx = new Ctx();
  return audioCtx;
};

const safeResumeAudio = async () => {
  const ctx = getAudioCtx();
  if (ctx && ctx.state === 'suspended') {
    try { await ctx.resume(); } catch (_) {}
  }
};

const playBeep = async (freq = 900, vol = 0.05, duration = 0.1) => {
  const ctx = getAudioCtx();
  if (!ctx) return;
  await safeResumeAudio();
  const osc = ctx.createOscillator();
  const gain = ctx.createGain();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(freq, ctx.currentTime);
  gain.gain.setValueAtTime(0.0001, ctx.currentTime);
  gain.gain.exponentialRampToValueAtTime(vol, ctx.currentTime + 0.01);
  gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + duration);
  osc.connect(gain);
  gain.connect(ctx.destination);
  osc.start();
  osc.stop(ctx.currentTime + duration + 0.05);
};

const playCountdownTriple = async () => {
  playBeep(950, 0.06, 0.05);
  setTimeout(() => playBeep(950, 0.06, 0.05), 150);
};

const playTransitionThud = async () => {
  playBeep(350, 0.1, 0.4);
};

const triggerHaptic = (style = 'medium') => {
  if (typeof navigator !== 'undefined' && navigator.vibrate) {
    if (style === 'heavy') navigator.vibrate([50, 50, 50]);
    else if (style === 'medium') navigator.vibrate(50);
    else navigator.vibrate(20);
  }
};

